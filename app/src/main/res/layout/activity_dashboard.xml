<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0F14">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/dashboardTitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🪖 Command Center"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="10dp" />

        <TextView
            android:id="@+id/dashboardSubtitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Your discipline economy starts here."
            android:textColor="#9EABB8"
            android:textSize="15sp"
            android:gravity="center"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="20dp" />

        <LinearLayout
            android:id="@+id/dashboardStatsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#151B23"
            android:padding="18dp"
            android:layout_marginBottom="22dp">

            <TextView
                android:id="@+id/dashboardRankText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🏅 Rank: Recruit"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/dashboardLeisureCreditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🎮 Leisure Credits: 00:00"
                android:textColor="#4CAF50"
                android:textSize="19sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/dashboardDebtText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔥 Discipline Debt: 00:00"
                android:textColor="#FF7043"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="10dp" />

            <TextView
                android:id="@+id/dashboardStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🟠 Status: Awaiting orders"
                android:textColor="#FFB74D"
                android:textSize="16sp"
                android:textStyle="bold"
                android:gravity="center" />

        </LinearLayout>

        <TextView
            android:id="@+id/dashboardNavigationTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mission Areas"
            android:textColor="#FFFFFF"
            android:textSize="21sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/openFocusPageButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⏱️ Focus and Credits"
            android:textAllCaps="false"
            android:backgroundTint="#1B5E20"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/openDistractionPageButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🚫 Distraction Control"
            android:textAllCaps="false"
            android:backgroundTint="#BF360C"
            android:textColor="#FFFFFF"
            android:layout_marginTop="10dp" />

        <Button
            android:id="@+id/openMissionsPageButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎯 Daily Missions"
            android:textAllCaps="false"
            android:backgroundTint="#0D47A1"
            android:textColor="#FFFFFF"
            android:layout_marginTop="10dp" />

        <Button
            android:id="@+id/openReportsPageButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📊 Reports / Brain"
            android:textAllCaps="false"
            android:backgroundTint="#4A148C"
            android:textColor="#FFFFFF"
            android:layout_marginTop="10dp" />

        <Button
            android:id="@+id/openSettingsPageButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚙️ Settings"
            android:textAllCaps="false"
            android:backgroundTint="#455A64"
            android:textColor="#FFFFFF"
            android:layout_marginTop="10dp" />

        <Button
            android:id="@+id/openControlPanelButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🛠️ Open Current Control Panel"
            android:textAllCaps="false"
            android:backgroundTint="#263238"
            android:textColor="#FFFFFF"
            android:layout_marginTop="18dp"
            android:layout_marginBottom="22dp" />

    </LinearLayout>

</ScrollView>