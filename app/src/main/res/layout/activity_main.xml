<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0F14">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- HEADER -->
        <TextView
            android:id="@+id/appTitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🪖 Mental Coach"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/appSubtitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Discipline • Focus • Execution"
            android:textColor="#9EABB8"
            android:textSize="15sp"
            android:gravity="center"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/monitoringStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status: Monitoring inactive"
            android:textColor="#FFB74D"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- MAIN COACH CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#151B23"
            android:padding="18dp"
            android:layout_marginBottom="18dp">

            <TextView
                android:id="@+id/coachMessageText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ready for orders, soldier."
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/timerText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No active timer"
                android:textColor="#9EABB8"
                android:textSize="18sp"
                android:gravity="center" />

            <TextView
                android:id="@+id/leisureCreditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🎮 Leisure Credits: 00:00"
                android:textColor="#4CAF50"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginTop="12dp" />

        </LinearLayout>

        <!-- COACH COMMANDS -->
        <TextView
            android:id="@+id/coachSectionTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚔️ Coach Commands"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/generalButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="General Command"
            android:textAllCaps="false"
            android:backgroundTint="#263238"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/distractionButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Distraction Warning"
            android:textAllCaps="false"
            android:backgroundTint="#BF360C"
            android:textColor="#FFFFFF"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/studyButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Study Command"
            android:textAllCaps="false"
            android:backgroundTint="#1B5E20"
            android:textColor="#FFFFFF"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/workoutButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Workout Command"
            android:textAllCaps="false"
            android:backgroundTint="#0D47A1"
            android:textColor="#FFFFFF"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/emergencyButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Emergency Reset"
            android:textAllCaps="false"
            android:backgroundTint="#B71C1C"
            android:textColor="#FFFFFF"
            android:layout_marginTop="8dp" />

        <!-- FOCUS TIMER -->
        <TextView
            android:id="@+id/focusSectionTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⏱️ Focus Timer"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/quickResetButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Quick Reset - 10 Seconds"
            android:textAllCaps="false"
            android:backgroundTint="#37474F"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/miniFocusButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mini Focus - 1 Minute"
            android:textAllCaps="false"
            android:backgroundTint="#37474F"
            android:textColor="#FFFFFF"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/deepFocusButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Deep Focus - 25 Minutes"
            android:textAllCaps="false"
            android:backgroundTint="#37474F"
            android:textColor="#FFFFFF"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/cancelTimerButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cancel Timer"
            android:textAllCaps="false"
            android:backgroundTint="#795548"
            android:textColor="#FFFFFF"
            android:layout_marginTop="8dp" />

        <!-- DISTRACTION LIST -->
        <TextView
            android:id="@+id/distractionListSectionTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🚫 Distraction Apps"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="10dp" />

        <EditText
            android:id="@+id/distractionInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Type package name manually"
            android:textColor="#FFFFFF"
            android:textColorHint="#7D8A99"
            android:backgroundTint="#607D8B"
            android:singleLine="true"
            android:padding="10dp" />

        <Button
            android:id="@+id/saveDistractionButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Distraction"
            android:textAllCaps="false"
            android:backgroundTint="#2E7D32"
            android:textColor="#FFFFFF"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/removeDistractionButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Remove Distraction"
            android:textAllCaps="false"
            android:backgroundTint="#C62828"
            android:textColor="#FFFFFF"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/distractionListText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No distractions saved yet."
            android:textColor="#C5CED8"
            android:textSize="15sp"
            android:background="#151B23"
            android:padding="12dp"
            android:layout_marginTop="10dp" />

        <!-- INSTALLED APP PICKER -->
        <TextView
            android:id="@+id/installedAppsSectionTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📱 Installed App Picker"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="10dp" />

        <EditText
            android:id="@+id/appSearchInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Search installed apps"
            android:textColor="#FFFFFF"
            android:textColorHint="#7D8A99"
            android:backgroundTint="#607D8B"
            android:singleLine="true"
            android:padding="10dp" />

        <Button
            android:id="@+id/loadInstalledAppsButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Load Installed Apps"
            android:textAllCaps="false"
            android:backgroundTint="#1565C0"
            android:textColor="#FFFFFF"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/installedAppsText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Installed apps will appear here."
            android:textColor="#9EABB8"
            android:textSize="14sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp" />

        <ListView
            android:id="@+id/installedAppsListView"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:background="#151B23"
            android:divider="#2C3642"
            android:dividerHeight="1dp" />

        <!-- MONITORING TOOLS -->
        <TextView
            android:id="@+id/toolsSectionTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🛠️ Monitoring Tools"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="10dp" />

        <Button
            android:id="@+id/grantUsageAccessButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Grant Usage Access"
            android:textAllCaps="false"
            android:backgroundTint="#455A64"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/checkCurrentAppButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Check Current App"
            android:textAllCaps="false"
            android:backgroundTint="#455A64"
            android:textColor="#FFFFFF"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/startMonitoringButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start In-App Monitoring"
            android:textAllCaps="false"
            android:backgroundTint="#2E7D32"
            android:textColor="#FFFFFF"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/stopMonitoringButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Stop In-App Monitoring"
            android:textAllCaps="false"
            android:backgroundTint="#C62828"
            android:textColor="#FFFFFF"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/startServiceMonitoringButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start Background Monitoring"
            android:textAllCaps="false"
            android:backgroundTint="#1B5E20"
            android:textColor="#FFFFFF"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/stopServiceMonitoringButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Stop Background Monitoring"
            android:textAllCaps="false"
            android:backgroundTint="#B71C1C"
            android:textColor="#FFFFFF"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/testNotificationButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Test Notification"
            android:textAllCaps="false"
            android:backgroundTint="#6A1B9A"
            android:textColor="#FFFFFF"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp" />

    </LinearLayout>

</ScrollView>